rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == "tjinvestoficial@gmail.com";
    }

    // Configuração de URLs de busca
    match /config_urls_busca/{urlId} {
      allow read: if true;
      allow write: if true;
    }

    // Imoveis collection
    match /imoveis/{imovelId} {
      allow read: if true;
      allow write: if true;
    }

    // Import jobs collection
    match /import_jobs/{jobId} {
      allow read: if true;
      allow write: if true;
    }

    // Configuração de estados
    match /config_estados/{estadoId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
